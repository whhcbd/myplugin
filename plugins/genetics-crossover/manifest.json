{
  "id": "genetics-crossover",
  "version": "1.0.0",
  "subject": "genetics",
  "name": "交叉互换图谱插件",
  "keywords": [
    "交叉互换",
    "染色体",
    "重组",
    "基因连锁",
    "着丝粒",
    "交叉点",
    "减数分裂",
    "基因定位",
    "连锁图谱"
  ],
  "entry": {
    "js": "dist/index.esm.js"
  },
  "capabilities": [
    {
      "component_id": "CrossoverMap",
      "name": "染色体交叉互换图谱",
      "tags": ["交叉互换", "染色体", "连锁", "重组", "基因定位", "着丝粒"],
      "props_schema": {
        "chromosomeId": {
          "type": "string",
          "default": "1",
          "description": "染色体编号，如 1、2、X"
        },
        "chromosomeLength": {
          "type": "number",
          "default": 100,
          "description": "染色体遗传长度（cM）"
        },
        "genes": {
          "type": "array",
          "default": [
            { "name": "A", "position": 10, "color": "#2563eb" },
            { "name": "B", "position": 30, "color": "#16a34a" },
            { "name": "C", "position": 55, "color": "#7c3aed" },
            { "name": "D", "position": 75, "color": "#ea580c" }
          ],
          "description": "基因位点数组，每项含 name、position（cM）、color（可选）"
        },
        "crossoverPoints": {
          "type": "array",
          "default": [
            { "position": 20, "label": "交叉点1", "type": "single", "confidence": "high" },
            { "position": 65, "label": "交叉点2", "type": "single", "confidence": "medium" }
          ],
          "description": "交叉点数组，每项含 position（cM）、label（可选）、type（可选 single/double/multiple）、confidence（可选 high/medium/low）"
        },
        "centromerePosition": {
          "type": "object",
          "default": { "position": 48 },
          "description": "着丝粒位置信息，含 position（cM），null 则默认为染色体中间"
        },
        "bands": {
          "type": "array",
          "default": [],
          "description": "染色体带型数组，每项含 start、end、name、type（G-dark/G-light/R-dark/R-light）"
        },
        "showCentromere": {
          "type": "boolean",
          "default": true,
          "description": "是否显示着丝粒"
        },
        "showRecombinationFreq": {
          "type": "boolean",
          "default": true,
          "description": "是否显示重组频率"
        },
        "interactive": {
          "type": "boolean",
          "default": true,
          "description": "是否允许点击基因和交叉点查看详情"
        },
        "maternalLabel": {
          "type": "string",
          "default": "母源",
          "description": "母源染色体标签"
        },
        "paternalLabel": {
          "type": "string",
          "default": "父源",
          "description": "父源染色体标签"
        }
      },
      "a2ui_hint": "CrossoverMap 组件可视化染色体交叉互换图谱。LLM只需通过 properties 传入 chromosomeId（染色体编号）、chromosomeLength（长度cM）、genes（基因位点数组）和 crossoverPoints（交叉点数组）即可。组件已内置着丝粒标注、重组频率计算、带型显示和点击交互，不需要额外生成控件。",
      "expresses": [
        "染色体交叉互换位置",
        "基因连锁关系",
        "重组频率计算",
        "着丝粒与基因相对位置",
        "染色体带型模式",
        "减数分裂交叉互换"
      ],
      "educational_use": "帮助学生理解减数分裂中染色体交叉互换的机制，通过可视化图谱展示基因连锁、重组频率和基因定位的关系",
      "cannot_express": [
        "减数分裂全过程动画",
        "三维染色体结构",
        "基因表达调控",
        "表观遗传修饰",
        "DNA序列级别细节"
      ]
    }
  ]
}
